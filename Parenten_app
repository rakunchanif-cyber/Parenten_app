<body class="bg-slate-50 text-slate-800 antialiased selection:bg-blue-900 selection:text-white">

    <div id="login-page" class="flex flex-col items-center justify-center min-h-screen bg-gradient-to-br from-slate-900 via-slate-950 to-blue-950 px-4">
        <div class="bg-white/95 backdrop-blur-md p-10 rounded-2xl shadow-2xl w-full max-w-md border border-white/20 transition-all duration-300">
            <div class="flex justify-center mb-6">
                <div class="relative w-20 h-20 bg-slate-900 flex items-center justify-center rounded-xl shadow-lg border border-slate-800">
                    <span class="text-white text-5xl font-black tracking-tighter">R</span>
                    <div class="absolute left-2.5 top-5.5 w-0 h-0 border-t-[10px] border-t-transparent border-l-[18px] border-l-red-500 border-bottom-[10px] border-bottom-transparent"></div>
                </div>
            </div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-wider mb-2 text-center">PARENTEN</h1>
            <p class="text-sm text-slate-500 text-center mb-8">Operational & Infrastructure Dashboard</p>
            
            <form id="form-login" onsubmit="handleLogin(event)" class="space-y-5">
                <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5">Email or NRPP</label>
                    <div class="relative">
                        <input type="text" id="login-username" placeholder="Masukkan NRPP Admin: 10018093..." required class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-950 text-sm font-medium transition-all">
                        <i class="fa fa-user absolute left-3.5 top-3.5 text-slate-400 text-sm"></i>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-slate-700 uppercase tracking-wider mb-1.5">Password</label>
                    <div class="relative">
                        <input type="password" placeholder="PASSWORD..." required class="w-full pl-10 pr-4 py-3 bg-slate-50 border border-slate-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-blue-950 text-sm font-medium transition-all">
                        <i class="fa fa-lock absolute left-3.5 top-3.5 text-slate-400 text-sm"></i>
                    </div>
                </div>
                <button type="submit" class="w-full bg-slate-900 text-white font-bold py-3.5 rounded-xl hover:bg-slate-800 shadow-lg hover:shadow-xl transition-all duration-200 cursor-pointer text-sm tracking-wide">LOG IN</button>
            </form>
        </div>
    </div>

    <div id="main-app" class="hidden flex h-screen overflow-hidden relative">
        
        <div id="sidebar-backdrop" onclick="toggleSidebar()" class="hidden fixed inset-0 bg-slate-950/50 z-20 lg:hidden transition-opacity duration-300"></div>
        
        <aside id="sidebar-container" class="fixed inset-y-0 left-0 -translate-x-full lg:translate-x-0 w-72 bg-slate-950 text-slate-400 flex flex-col justify-between shadow-2xl z-30 border-r border-slate-800 shrink-0 transition-transform duration-300 ease-in-out lg:static">
            <div class="flex flex-col h-full overflow-y-auto">
                <div class="p-6 bg-slate-950 border-b border-slate-900 flex items-center justify-between sticky top-0 z-10">
                    <div class="flex items-center space-x-3">
                        <div class="w-9 h-9 bg-white flex items-center justify-center rounded-lg font-black text-slate-900 relative shadow">
                            <span>R</span>
                            <div class="absolute left-1 top-2.5 w-0 h-0 border-t-[4px] border-t-transparent border-l-[8px] border-l-red-500 border-bottom-[4px] border-bottom-transparent"></div>
                        </div>
                        <span class="text-xl font-bold text-white tracking-wider">PARENTEN</span>
                    </div>
                    <button onclick="toggleSidebar()" class="lg:hidden w-8 h-8 flex items-center justify-center rounded-lg bg-slate-900 hover:bg-slate-800 text-slate-300 border border-slate-800 cursor-pointer">
                        <i class="fa fa-xmark text-sm"></i>
                    </button>
                </div>
                
                <div class="p-4 border-b border-slate-900 sticky top-[85px] bg-slate-950 z-10">
                    <div class="relative">
                        <input type="text" id="global-search" oninput="handleSearch()" placeholder="Cari data aktual..." class="w-full bg-slate-900 text-white pl-10 pr-4 py-2.5 rounded-xl text-sm border border-slate-800 focus:outline-none focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all">
                        <i class="fa fa-search absolute left-3.5 top-3.5 text-slate-500 text-sm"></i>
                    </div>
                </div>

                <nav class="p-4 space-y-1.5 flex-1">
                    <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600 px-3 mb-2">Main Menu</p>
                    <button onclick="switchMenu('home')" id="btn-home" class="sidebar-menu-btn w-full flex items-center space-x-3 px-4 py-3 rounded-xl text-sm font-semibold transition-all duration-150 text-left hover:bg-slate-900 hover:text-white active">
                        <i class="fa-solid fa-chart-pie w-5 text-center text-base"></i> <span>Home Dashboard</span>
                    </button>
                    <button onclick="switchMenu('rfu')" id="btn-rfu" class="sidebar-menu-btn w-full flex items-center space-x-3 px-4 py-3 rounded-xl text-sm font-semibold transition-all duration-150 text-left hover:bg-slate-900 hover:text-white">
                        <i class="fa-solid fa-boxes-packing w-5 text-center text-base"></i> <span>RFU Nasional</span>
                    </button>
                    <button onclick="switchMenu('proyek')" id="btn-proyek" class="sidebar-menu-btn w-full flex items-center space-x-3 px-4 py-3 rounded-xl text-sm font-semibold transition-all duration-150 text-left hover:bg-slate-900 hover:text-white">
                        <i class="fa-solid fa-folder-plus w-5 text-center text-base"></i> <span>Input Proyek Lapangan</span>
                    </button>
                    <button onclick="switchMenu('stok')" id="btn-stok" class="sidebar-menu-btn w-full flex items-center space-x-3 px-4 py-3 rounded-xl text-sm font-semibold duration-150 text-left hover:bg-slate-900 hover:text-white">
                        <i class="fa-solid fa-warehouse w-5 text-center text-base"></i> <span>Stok Part & Lokasi</span>
                    </button>
                    
                    <button onclick="switchMenu('arsip-cabang')" id="btn-arsip-cabang" class="sidebar-menu-btn w-full flex items-center space-x-3 px-4 py-3 rounded-xl text-sm font-semibold duration-150 text-left hover:bg-slate-900 hover:text-white text-amber-400 hidden">
                        <i class="fa-solid fa-folder-open w-5 text-center text-base"></i> <span>Data Arsip Cabang Center</span>
                    </button>
                </nav>
            </div>

            <div class="p-4 bg-slate-950 border-t border-slate-900 text-xs">
                <div class="flex items-center space-x-3 mb-4 bg-slate-900/50 p-3 rounded-xl border border-slate-900">
                    <div class="w-9 h-9 bg-blue-900/50 text-blue-400 rounded-xl flex items-center justify-center text-sm font-bold border border-blue-800"><i class="fa fa-user-gear"></i></div>
                    <div class="overflow-hidden">
                        <p class="font-bold text-white text-sm truncate" id="user-display">10018093</p>
                        <p class="text-slate-500 text-[11px]">Divisi Operational Hub</p>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-2">
                    <button onclick="refreshApp()" class="bg-slate-900 hover:bg-slate-800 text-slate-300 font-bold py-2 px-3 rounded-xl border border-slate-800 flex items-center justify-center space-x-1.5 transition-all cursor-pointer">
                        <i class="fa fa-arrows-rotate text-blue-400"></i> <span>Refresh</span>
                    </button>
                    <button onclick="handleLogout()" class="bg-red-950/40 hover:bg-red-900 text-red-400 hover:text-white font-bold py-2 px-3 rounded-xl border border-red-900/60 flex items-center justify-center space-x-1.5 transition-all cursor-pointer">
                        <i class="fa fa-power-off"></i> <span>Log Out</span>
                    </button>
                </div>
            </div>
        </aside>

        <main class="flex-1 flex flex-col h-full overflow-hidden w-full">
            
            <header class="bg-white/80 backdrop-blur-md border-b border-slate-200/80 px-4 md:px-8 py-4 flex justify-between items-center shrink-0 sticky top-0 z-10 gap-4">
                <div class="flex items-center space-x-3">
                    <button onclick="toggleSidebar()" class="p-2.5 rounded-xl bg-slate-100 hover:bg-slate-200 text-slate-800 border border-slate-200/60 transition-all cursor-pointer flex items-center justify-center">
                        <i class="fa fa-bars text-lg"></i>
                    </button>
                    <div>
                        <p class="text-[10px] md:text-xs font-bold text-slate-400 uppercase tracking-widest">Workspace Panel</p>
                        <h2 id="page-title" class="text-lg md:text-2xl font-extrabold text-slate-900 tracking-tight truncate">Home Dashboard</h2>
                    </div>
                </div>
                <button id="btn-master-excel" onclick="exportAllToExcel()" class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold py-2.5 px-4 rounded-xl shadow-md hover:shadow-lg transition-all duration-200 flex items-center space-x-2 cursor-pointer shrink-0 hidden">
                    <i class="fa fa-file-excel text-sm"></i> <span>Simpan & Download Excel</span>
                </button>
            </header>

            <div class="flex-1 overflow-y-auto p-4 md:p-8">
                <div class="max-w-7xl mx-auto space-y-8">

                    <section id="sec-home" class="space-y-6">
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div onclick="showQuickDataDetail('penarikan')" class="bg-white p-5 rounded-2xl border border-slate-200 hover:border-blue-600 hover:bg-blue-50/20 transition-all shadow-sm flex items-center justify-between cursor-pointer group">
                                <div>
                                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wide group-hover:text-blue-600">Total Unit Penarikan</p>
                                    <h4 id="count-penarikan" class="text-3xl font-black text-blue-900 mt-1">0</h4>
                                    <span class="text-[10px] font-medium text-slate-400 group-hover:text-blue-500">Klik untuk rincian data &rarr;</span>
                                </div>
                                <div class="w-12 h-12 bg-blue-50 group-hover:bg-blue-600 group-hover:text-white text-blue-600 rounded-xl flex items-center justify-center transition-colors"><i class="fa fa-truck-ramp-box text-lg"></i></div>
                            </div>
                            
                            <div onclick="showQuickDataDetail('perbaikan')" class="bg-white p-5 rounded-2xl border border-slate-200 hover:border-amber-500 hover:bg-amber-50/20 transition-all shadow-sm flex items-center justify-between cursor-pointer group">
                                <div>
                                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wide group-hover:text-amber-600">Total Progres Perbaikan</p>
                                    <h4 id="count-perbaikan" class="text-3xl font-black text-amber-600 mt-1">0</h4>
                                    <span class="text-[10px] font-medium text-slate-400 group-hover:text-amber-500">Klik untuk rincian data &rarr;</span>
                                </div>
                                <div class="w-12 h-12 bg-amber-50 group-hover:bg-amber-500 group-hover:text-white text-amber-600 rounded-xl flex items-center justify-center transition-colors"><i class="fa fa-screwdriver-wrench text-lg"></i></div>
                            </div>
                            
                            <div onclick="showQuickDataDetail('delivery')" class="bg-white p-5 rounded-2xl border border-slate-200 hover:border-emerald-500 hover:bg-emerald-50/20 transition-all shadow-sm flex items-center justify-between cursor-pointer group">
                                <div>
                                    <p class="text-xs font-bold text-slate-400 uppercase tracking-wide group-hover:text-emerald-600">Total RFU Delivery</p>
                                    <h4 id="count-delivery" class="text-3xl font-black text-emerald-600 mt-1">0</h4>
                                    <span class="text-[10px] font-medium text-slate-400 group-hover:text-emerald-500">Klik untuk rincian data &rarr;</span>
                                </div>
                                <div class="w-12 h-12 bg-emerald-50 group-hover:bg-emerald-500 group-hover:text-white text-emerald-600 rounded-xl flex items-center justify-center transition-colors"><i class="fa fa-truck-direct text-lg"></i></div>
                            </div>
                        </div>

                        <div id="quick-detail-card" class="bg-white border border-slate-200 rounded-2xl shadow-md p-5 hidden transition-all duration-300">
                            <div class="flex items-center justify-between border-b border-slate-100 pb-3 mb-4">
                                <div class="flex items-center space-x-2">
                                    <div id="quick-detail-badge" class="w-2.5 h-5 rounded-full bg-blue-600"></div>
                                    <h4 id="quick-detail-title" class="font-bold text-slate-900 text-sm md:text-base">Detail Log Aktual</h4>
                                </div>
                                <button onclick="document.getElementById('quick-detail-card').classList.add('hidden')" class="text-slate-400 hover:text-slate-600 font-bold text-xs p-1 px-2.5 bg-slate-100 hover:bg-slate-200 rounded-lg cursor-pointer"><i class="fa fa-xmark"></i> Tutup Panel</button>
                            </div>
                            <div class="overflow-x-auto">
                                <table class="w-full text-left text-xs md:text-sm border-collapse">
                                    <thead id="quick-detail-thead" class="bg-slate-900 text-white font-bold uppercase tracking-wide"></thead>
                                    <tbody id="quick-detail-tbody" class="divide-y divide-slate-100 text-slate-700"></tbody>
                                </table>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                            <div class="bg-white p-4 md:p-6 rounded-2xl shadow-sm border border-slate-100">
                                <div class="flex items-center justify-between mb-4 border-b border-slate-50 pb-2">
                                    <div class="flex items-center space-x-2.5">
                                        <div class="w-2.5 h-6 bg-blue-600 rounded-full"></div>
                                        <h3 class="text-xs md:text-sm font-bold text-slate-800 uppercase tracking-wider">Populasi Unit Lemah Abang</h3>
                                    </div>
                                    <span class="bg-blue-100 text-blue-900 text-[11px] font-extrabold px-3 py-1 rounded-full border border-blue-200">Tahun 2026</span>
                                </div>
                                <div class="h-64"><canvas id="chartLA"></canvas></div>
                            </div>
                            
                            <div class="bg-white p-4 md:p-6 rounded-2xl shadow-sm border border-slate-100">
                                <div class="flex items-center justify-between mb-4 border-b border-slate-50 pb-2">
                                    <div class="flex items-center space-x-2.5">
                                        <div class="w-2.5 h-6 bg-amber-500 rounded-full"></div>
                                        <h3 class="text-xs md:text-sm font-bold text-slate-800 uppercase tracking-wider">Populasi Unit Surabaya</h3>
                                    </div>
                                    <span class="bg-amber-100 text-amber-900 text-[11px] font-extrabold px-3 py-1 rounded-full border border-amber-200">Tahun 2026</span>
                                </div>
                                <div class="h-64"><canvas id="chartSBY"></canvas></div>
                            </div>
                            
                            <div class="bg-white p-4 md:p-6 rounded-2xl shadow-sm border border-slate-100">
                                <div class="flex items-center justify-between mb-4 border-b border-slate-50 pb-2">
                                    <div class="flex items-center space-x-2.5">
                                        <div class="w-2.5 h-6 bg-purple-600 rounded-full"></div>
                                        <h3 class="text-xs md:text-sm font-bold text-slate-800 uppercase tracking-wider">Populasi Unit Medan/Semarang</h3>
                                    </div>
                                    <span class="bg-purple-100 text-purple-900 text-[11px] font-extrabold px-3 py-1 rounded-full border border-purple-200">Tahun 2026</span>
                                </div>
                                <div class="h-64"><canvas id="chartMDN"></canvas></div>
                            </div>
                            
                            <div class="bg-white p-4 md:p-6 rounded-2xl shadow-sm border border-slate-100">
                                <div class="flex items-center justify-between mb-4 border-b border-slate-50 pb-2">
                                    <div class="flex items-center space-x-2.5">
                                        <div class="w-2.5 h-6 bg-emerald-500 rounded-full"></div>
                                        <h3 class="text-xs md:text-sm font-bold text-slate-800 uppercase tracking-wider">Grafik Perbandingan RFU Nasional</h3>
                                    </div>
                                    <span class="bg-emerald-100 text-emerald-900 text-[11px] font-extrabold px-3 py-1 rounded-full border border-emerald-200">Tahun 2026</span>
                                </div>
                                <div class="h-64"><canvas id="chartRFU"></canvas></div>
                            </div>
                        </div>
                    </section>

                    <section id="sec-rfu" class="hidden">
                        <div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                            <div class="p-6 border-b border-slate-100 bg-slate-50/50">
                                <h3 class="font-bold text-slate-800 text-base">Arsip Excel Terintegrasi - Unit Ready & Done Repair</h3>
                            </div>
                            <div class="overflow-x-auto">
                                <table class="w-full text-left border-collapse" id="table-rfu">
                                    <thead class="bg-slate-900 text-slate-200 text-xs font-bold uppercase tracking-wider">
                                        <tr>
                                            <th class="p-4 border-b">Tanggal Kerja</th>
                                            <th class="p-4 border-b">Wilayah Cabang</th>
                                            <th class="p-4 border-b">Type Unit</th>
                                            <th class="p-4 border-b">Serial Number</th>
                                            <th class="p-4 border-b">Hour Meter</th>
                                            <th class="p-4 border-b">Kondisi / Hasil</th>
                                        </tr>
                                    </thead>
                                    <tbody class="text-sm divide-y divide-slate-100 text-slate-700" id="body-rfu"></tbody>
                                </table>
                            </div>
                        </div>
                    </section>

                    <section id="sec-proyek" class="hidden space-y-6">
                        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-3">
                            <button onclick="openForm('penarikan')" class="bg-white hover:bg-slate-50 p-4 rounded-xl border border-slate-200/80 font-bold text-xs text-slate-700 text-center flex flex-col items-center justify-center gap-2 shadow-sm cursor-pointer">
                                <div class="w-10 h-10 bg-blue-50 text-blue-600 rounded-lg flex items-center justify-center text-base"><i class="fa fa-truck-ramp-box"></i></div>Penarikan Unit
                            </button>
                            <button onclick="openForm('perbaikan')" class="bg-white hover:bg-slate-50 p-4 rounded-xl border border-slate-200/80 font-bold text-xs text-slate-700 text-center flex flex-col items-center justify-center gap-2 shadow-sm cursor-pointer">
                                <div class="w-10 h-10 bg-amber-50 text-amber-600 rounded-lg flex items-center justify-center text-base"><i class="fa fa-screwdriver-wrench"></i></div>Perbaikan Unit
                            </button>
                            <button onclick="openForm('delivery')" class="bg-white hover:bg-slate-50 p-4 rounded-xl border border-slate-200/80 font-bold text-xs text-slate-700 text-center flex flex-col items-center justify-center gap-2 shadow-sm cursor-pointer">
                                <div class="w-10 h-10 bg-emerald-50 text-emerald-600 rounded-lg flex items-center justify-center text-base"><i class="fa fa-truck-direct"></i></div>Delivery Unit
                            </button>
                            <button onclick="openForm('loan')" class="bg-white hover:bg-slate-50 p-4 rounded-xl border border-slate-200/80 font-bold text-xs text-slate-700 text-center flex flex-col items-center justify-center gap-2 shadow-sm cursor-pointer">
                                <div class="w-10 h-10 bg-purple-50 text-purple-600 rounded-lg flex items-center justify-center text-base"><i class="fa fa-arrow-right-arrow-left"></i></div>Loan Part
                            </button>
                        </div>

                        <div id="form-container" class="bg-white p-5 md:p-8 rounded-2xl shadow-sm border border-slate-100 hidden">
                            <h3 id="form-title" class="text-base md:text-lg font-bold text-slate-900 border-b border-slate-100 pb-4 mb-6">Form Input</h3>
                            <form id="active-form" onsubmit="handleSubmitForm(event)">
                                <div id="div-cabang" class="mb-6 max-w-md">
                                    <label class="block text-xs font-bold text-slate-500 uppercase tracking-wider mb-2">Pilih Wilayah Cabang / Branch</label>
                                    <select id="input-cabang" class="w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium">
                                        <option value="Lemah Abang">Cabang Lemah Abang</option>
                                        <option value="Surabaya">Cabang Surabaya</option>
                                        <option value="Medan/Semarang">Cabang Medan/Semarang (Cab Lain)</option>
                                    </select>
                                </div>
                                <div id="form-fields-grid" class="grid grid-cols-1 md:grid-cols-2 gap-5"></div>
                                <div class="mt-8 pt-5 border-t border-slate-100 flex justify-end space-x-3">
                                    <button type="button" onclick="closeFormContainer()" class="px-5 py-2.5 text-sm font-semibold text-slate-500">Batal</button>
                                    <button type="submit" class="px-7 py-2.5 text-sm bg-blue-900 text-white font-bold rounded-xl shadow-md">Simpan Data</button>
                                </div>
                            </form>
                        </div>
                    </section>

                    <section id="sec-stok" class="hidden">
                        <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100">
                            <table class="w-full text-left border-collapse">
                                <thead class="bg-slate-900 text-white text-xs uppercase tracking-wider"><th class="p-4">Part Name</th><th class="p-4">Part Number</th><th class="p-4">Stok</th><th class="p-4">Bin Lokasi</th></thead>
                                <tbody class="text-sm divide-y divide-slate-100 text-slate-700">
                                    <tr><td class="p-4 font-semibold">Hydraulic Filter</td><td class="p-4">HF-90882</td><td class="p-4 text-blue-600 font-bold">14 Pcs</td><td class="p-4">Gudang LA - Rak A2</td></tr>
                                    <tr><td class="p-4 font-semibold">Contactor 24V</td><td class="p-4">CT-1102</td><td class="p-4 text-blue-600 font-bold">5 Pcs</td><td class="p-4">Gudang SBY - Rak B1</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </section>

                    <section id="sec-arsip-cabang" class="hidden space-y-6">
                        <div class="flex flex-wrap bg-slate-900 p-2 rounded-2xl gap-2 shadow-inner">
                            <button onclick="switchArsipKategori('penarikan')" id="btn-kat-penarikan" class="kat-btn flex-1 text-center py-3 px-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all bg-white text-slate-900 shadow">Penarikan Unit</button>
                            <button onclick="switchArsipKategori('perbaikan')" id="btn-kat-perbaikan" class="kat-btn flex-1 text-center py-3 px-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all text-slate-400 hover:text-white">Perbaikan Unit</button>
                            <button onclick="switchArsipKategori('delivery')" id="btn-kat-delivery" class="kat-btn flex-1 text-center py-3 px-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all text-slate-400 hover:text-white">Pengiriman (Delivery)</button>
                            <button onclick="switchArsipKategori('loan')" id="btn-kat-loan" class="kat-btn flex-1 text-center py-3 px-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all text-slate-400 hover:text-white">Loan Part</button>
                        </div>

                        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden shadow-sm">
                            <div class="border-b border-slate-200 bg-slate-50 flex flex-col sm:flex-row sm:items-center sm:justify-between p-2 gap-4">
                                <div class="flex overflow-x-auto">
                                    <button onclick="switchArsipCabangTab('Lemah Abang')" id="tab-cab-la" class="cab-tab-btn px-4 md:px-6 py-3 border-b-2 border-blue-900 text-blue-900 font-bold text-xs md:text-sm tracking-wide">Cabang Lemah Abang</button>
                                    <button onclick="switchArsipCabangTab('Surabaya')" id="tab-cab-sby" class="cab-tab-btn px-4 md:px-6 py-3 border-b-2 border-transparent text-slate-500 font-semibold text-xs md:text-sm tracking-wide hover:text-slate-900">Cabang Surabaya</button>
                                    <button onclick="switchArsipCabangTab('Medan/Semarang')" id="tab-cab-lain" class="cab-tab-btn px-4 md:px-6 py-3 border-b-2 border-transparent text-slate-500 font-semibold text-xs md:text-sm tracking-wide hover:text-slate-900">Cabang Lain</button>
                                </div>
                                <button onclick="openFormLangsungDariArsip()" class="bg-blue-900 hover:bg-blue-800 text-white text-xs font-bold py-2 px-4 rounded-xl shadow transition-all cursor-pointer flex items-center gap-1.5 self-end sm:self-auto">
                                    <i class="fa fa-plus-circle"></i> Tambah Data Baru
                                </button>
                            </div>

                            <div class="p-4 overflow-x-auto">
                                <table class="w-full text-left text-xs md:text-sm border-collapse">
                                    <thead id="arsip-table-thead" class="bg-slate-100 text-slate-800 font-bold uppercase tracking-wider border-b border-slate-200"></thead>
                                    <tbody id="arsip-table-tbody" class="divide-y divide-slate-100 text-slate-700"></tbody>
                                </table>
                            </div>
                        </div>
                    </section>

                </div>
            </div>
        </main>
    </div>

    <div id="modal-edit-admin" class="hidden fixed inset-0 bg-slate-950/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-xl rounded-2xl shadow-2xl border border-slate-200 p-6 md:p-8 animate-in fade-in zoom-in-95 duration-200">
            <div class="flex justify-between items-center border-b border-slate-100 pb-4 mb-6">
                <div class="flex items-center space-x-2.5">
                    <div class="w-8 h-8 bg-blue-100 text-blue-700 rounded-xl flex items-center justify-center text-sm"><i class="fa fa-user-gear"></i></div>
                    <h3 id="modal-admin-title" class="font-extrabold text-slate-900 text-base md:text-lg">Edit Record Data (Admin)</h3>
                </div>
                <button onclick="closeEditModal()" class="w-8 h-8 flex items-center justify-center rounded-lg bg-slate-100 text-slate-500 hover:bg-slate-200 cursor-pointer"><i class="fa fa-xmark"></i></button>
            </div>
            <form id="form-edit-admin" onsubmit="handleSaveEditAdmin(event)">
                <div id="modal-fields-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4 max-h-[60vh] overflow-y-auto pr-2"></div>
                <div class="mt-6 pt-4 border-t border-slate-100 flex justify-end space-x-3">
                    <button type="button" onclick="closeEditModal()" class="px-5 py-2.5 text-sm font-semibold text-slate-500 cursor-pointer">Batal</button>
                    <button type="submit" class="px-6 py-2.5 text-sm bg-blue-900 text-white font-bold rounded-xl shadow-md hover:bg-blue-800 cursor-pointer">Simpan Perubahan</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        let DB_MASTER = { penarikan: [], perbaikan: [], delivery: [], loan: [] };
        let currentUserRole = 'operator'; 
        let activeCurrentFormType = '';
        let instancesChart = { LA: null, SBY: null, MDN: null, RFU: null };
        let currentArsipKategori = 'penarikan';
        let currentArsipCabang = 'Lemah Abang';
        let editTargetKategori = '';
        let editTargetIndex = -1;
        let isAdminInsertMode = false;

        function toggleSidebar() {
            document.getElementById('sidebar-container').classList.toggle('-translate-x-full');
            document.getElementById('sidebar-backdrop').classList.toggle('hidden');
        }

        function handleLogin(e) {
            e.preventDefault();
            const inputUser = document.getElementById('login-username').value.trim();
            document.getElementById('user-display').innerText = inputUser;
            
            if(inputUser === '10018093') {
                currentUserRole = 'admin';
                document.getElementById('btn-arsip-cabang').classList.remove('hidden'); 
                document.getElementById('btn-master-excel').classList.remove('hidden'); 
            } else {
                currentUserRole = 'operator';
                document.getElementById('btn-arsip-cabang').classList.add('hidden'); 
                document.getElementById('btn-master-excel').classList.add('hidden'); 
            }
            document.getElementById('login-page').classList.add('hidden');
            document.getElementById('main-app').classList.remove('hidden');
            switchMenu('home');
            refreshApp();
        }

        function handleLogout() {
            document.getElementById('main-app').classList.add('hidden');
            document.getElementById('login-page').classList.remove('hidden');
            document.getElementById('form-login').reset();
        }

        function refreshApp() {
            updateDashboardCounters();
            renderAllChartsAktual();
            renderRFUTable();
            if(currentUserRole === 'admin') renderFolderArsipData();
        }

        function switchMenu(menuName) {
            if(menuName === 'arsip-cabang' && currentUserRole !== 'admin') { alert("Akses Ditolak!"); return; }
            document.getElementById('sec-home').classList.add('hidden');
            document.getElementById('sec-rfu').classList.add('hidden');
            document.getElementById('sec-proyek').classList.add('hidden');
            document.getElementById('sec-stok').classList.add('hidden');
            document.getElementById('sec-arsip-cabang').classList.add('hidden');
            document.querySelectorAll('.sidebar-menu-btn').forEach(btn => btn.classList.remove('active'));

            if(menuName === 'home') {
                document.getElementById('sec-home').classList.remove('hidden');
                document.getElementById('btn-home').classList.add('active');
                document.getElementById('page-title').innerText = "Home Dashboard";
            } else if(menuName === 'rfu') {
                document.getElementById('sec-rfu').classList.remove('hidden');
                document.getElementById('btn-rfu').classList.add('active');
                document.getElementById('page-title').innerText = "RFU Nasional";
            } else if(menuName === 'proyek') {
                document.getElementById('sec-proyek').classList.remove('hidden');
                document.getElementById('btn-proyek').classList.add('active');
                document.getElementById('page-title').innerText = "Input Proyek Lapangan";
            } else if(menuName === 'stok') {
                document.getElementById('sec-stok').classList.remove('hidden');
                document.getElementById('btn-stok').classList.add('active');
                document.getElementById('page-title').innerText = "Stok Part & Lokasi";
            } else if(menuName === 'arsip-cabang') {
                document.getElementById('sec-arsip-cabang').classList.remove('hidden');
                document.getElementById('btn-arsip-cabang').classList.add('active');
                document.getElementById('page-title').innerText = "Folder Wadah Data Arsip Cabang Center";
                renderFolderArsipData();
            }
            if(window.innerWidth < 1024) toggleSidebar();
        }

        function switchArsipKategori(kategori) {
            currentArsipKategori = kategori;
            document.querySelectorAll('.kat-btn').forEach(btn => {
                btn.className = "kat-btn flex-1 text-center py-3 px-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all text-slate-400 hover:text-white";
            });
            document.getElementById(`btn-kat-${kategori}`).className = "kat-btn flex-1 text-center py-3 px-4 rounded-xl font-bold text-xs uppercase tracking-wider transition-all bg-white text-slate-900 shadow";
            renderFolderArsipData();
        }

        function switchArsipCabangTab(cabang) {
            currentArsipCabang = cabang;
            document.querySelectorAll('.cab-tab-btn').forEach(btn => {
                btn.className = "cab-tab-btn px-4 md:px-6 py-3 border-b-2 border-transparent text-slate-500 font-semibold text-xs md:text-sm tracking-wide hover:text-slate-900";
            });
            if(cabang === 'Lemah Abang') document.getElementById('tab-cab-la').className = "cab-tab-btn px-4 md:px-6 py-3 border-b-2 border-blue-900 text-blue-900 font-bold text-xs md:text-sm tracking-wide";
            if(cabang === 'Surabaya') document.getElementById('tab-cab-sby').className = "cab-tab-btn px-4 md:px-6 py-3 border-b-2 border-blue-900 text-blue-900 font-bold text-xs md:text-sm tracking-wide";
            if(cabang === 'Medan/Semarang') document.getElementById('tab-cab-lain').className = "cab-tab-btn px-4 md:px-6 py-3 border-b-2 border-blue-900 text-blue-900 font-bold text-xs md:text-sm tracking-wide";
            renderFolderArsipData();
        }

        function renderFolderArsipData() {
            if(currentUserRole !== 'admin') return;
            const thead = document.getElementById('arsip-table-thead');
            const tbody = document.getElementById('arsip-table-tbody');
            tbody.innerHTML = '';

            let dataTerfilter = [];
            DB_MASTER[currentArsipKategori].forEach((item, index) => {
                if(item.cabang === currentArsipCabang) { dataTerfilter.push({ ...item, originalIndex: index }); }
            });

            const actionHeader = `<th class="p-3 text-center w-44">Kontrol Utama</th>`;

            if(currentArsipKategori === 'penarikan') {
                thead.innerHTML = `<tr><th class="p-3">Tanggal</th><th class="p-3">Type Unit</th><th class="p-3">Serial Number</th><th class="p-3">Hour Meter</th><th class="p-3">Customer</th><th class="p-3">Kondisi Lapangan</th>${actionHeader}</tr>`;
                if(dataTerfilter.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="7" class="p-4 text-center text-slate-400">Belum ada data penarikan khusus cabang ini.</td></tr>`;
                } else {
                    dataTerfilter.forEach(item => {
                        tbody.innerHTML += `<tr><td class="p-3 font-medium">${item.tanggal}</td><td class="p-3 font-semibold text-slate-900">${item.type}</td><td class="p-3 font-mono">${item.sn}</td><td class="p-3">${item.hm} Hrs</td><td class="p-3">${item.customer}</td><td class="p-3 text-slate-500">${item.kondisi}</td><td class="p-3 flex items-center justify-center gap-1.5"><button onclick="openEditModalAdmin('penarikan', ${item.originalIndex})" class="text-blue-600 font-bold text-xs bg-blue-50 hover:bg-blue-100 py-1 px-2.5 rounded-lg cursor-pointer"><i class="fa fa-edit"></i> Ubah</button><button onclick="deleteRecordAdmin('penarikan', ${item.originalIndex})" class="text-red-600 font-bold text-xs bg-red-50 hover:bg-red-100 py-1 px-2.5 rounded-lg cursor-pointer"><i class="fa fa-trash"></i> Hapus</button></td></tr>`;
                    });
                }
            } else if(currentArsipKategori === 'perbaikan') {
                thead.innerHTML = `<tr><th class="p-3">Tanggal</th><th class="p-3">Type Unit</th><th class="p-3">Serial Number</th><th class="p-3">Action Kerja</th><th class="p-3">Nama Part</th><th class="p-3">Status</th>${actionHeader}</tr>`;
                if(dataTerfilter.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="7" class="p-4 text-center text-slate-400">Belum ada data perbaikan khusus cabang ini.</td></tr>`;
                } else {
                    dataTerfilter.forEach(item => {
                        let st = item.jenisJob === 'finish' ? '<span class="bg-emerald-100 text-emerald-800 text-[10px] font-bold px-2 py-0.5 rounded">Selesai</span>' : '<span class="bg-amber-100 text-amber-800 text-[10px] font-bold px-2 py-0.5 rounded">Proses</span>';
                        tbody.innerHTML += `<tr><td class="p-3">${item.tanggal}</td><td class="p-3 font-medium">${item.type}</td><td class="p-3 font-mono">${item.sn}</td><td class="p-3 text-slate-600">${item.action}</td><td class="p-3 font-semibold">${item.partName || 'N/A'}</td><td class="p-3">${st}</td><td class="p-3 flex items-center justify-center gap-1.5"><button onclick="openEditModalAdmin('perbaikan', ${item.originalIndex})" class="text-blue-600 font-bold text-xs bg-blue-50 hover:bg-blue-100 py-1 px-2.5 rounded-lg cursor-pointer"><i class="fa fa-edit"></i> Ubah</button><button onclick="deleteRecordAdmin('perbaikan', ${item.originalIndex})" class="text-red-600 font-bold text-xs bg-red-50 hover:bg-red-100 py-1 px-2.5 rounded-lg cursor-pointer"><i class="fa fa-trash"></i> Hapus</button></td></tr>`;
                    });
                }
            } else if(currentArsipKategori === 'delivery') {
                thead.innerHTML = `<tr><th class="p-3">Tanggal</th><th class="p-3">Type Unit</th><th class="p-3">Serial Number</th><th class="p-3">Hour Meter</th><th class="p-3">Customer</th><th class="p-3">Hasil Akhir</th>${actionHeader}</tr>`;
                if(dataTerfilter.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="7" class="p-4 text-center text-slate-400">Belum ada data delivery khusus cabang ini.</td></tr>`;
                } else {
                    dataTerfilter.forEach(item => {
                        tbody.innerHTML += `<tr><td class="p-3">${item.tanggal}</td><td class="p-3 font-semibold">${item.type}</td><td class="p-3 font-mono">${item.sn}</td><td class="p-3">${item.hm || 0} Hrs</td><td class="p-3">${item.customer}</td><td class="p-3 text-emerald-600 font-bold">${item.kondisi}</td><td class="p-3 flex items-center justify-center gap-1.5"><button onclick="openEditModalAdmin('delivery', ${item.originalIndex})" class="text-blue-600 font-bold text-xs bg-blue-50 hover:bg-blue-100 py-1 px-2.5 rounded-lg cursor-pointer"><i class="fa fa-edit"></i> Ubah</button><button onclick="deleteRecordAdmin('delivery', ${item.originalIndex})" class="text-red-600 font-bold text-xs bg-red-50 hover:bg-red-100 py-1 px-2.5 rounded-lg cursor-pointer"><i class="fa fa-trash"></i> Hapus</button></td></tr>`;
                    });
                }
            } else if(currentArsipKategori === 'loan') {
                thead.innerHTML = `<tr><th class="p-3">Tanggal</th><th class="p-3">Jenis Loan</th><th class="p-3">Part Name</th><th class="p-3">Part Number</th><th class="p-3">Qty</th><th class="p-3">PIC Req</th>${actionHeader}</tr>`;
                if(dataTerfilter.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="7" class="p-4 text-center text-slate-400">Belum ada mutasi part khusus cabang ini.</td></tr>`;
                } else {
                    dataTerfilter.forEach(item => {
                        tbody.innerHTML += `<tr><td class="p-3">${item.tanggal}</td><td class="p-3 font-bold text-purple-700">${item.typeLoan}</td><td class="p-3 font-semibold">${item.partName}</td><td class="p-3 font-mono">${item.partNo}</td><td class="p-3 font-bold">${item.qty} Pcs</td><td class="p-3 text-slate-500">${item.pic || 'N/A'}</td><td class="p-3 flex items-center justify-center gap-1.5"><button onclick="openEditModalAdmin('loan', ${item.originalIndex})" class="text-blue-600 font-bold text-xs bg-blue-50 hover:bg-blue-100 py-1 px-2.5 rounded-lg cursor-pointer"><i class="fa fa-edit"></i> Ubah</button><button onclick="deleteRecordAdmin('loan', ${item.originalIndex})" class="text-red-600 font-bold text-xs bg-red-50 hover:bg-red-100 py-1 px-2.5 rounded-lg cursor-pointer"><i class="fa fa-trash"></i> Hapus</button></td></tr>`;
                    });
                }
            }
        }

        function deleteRecordAdmin(kategori, index) {
            if(currentUserRole !== 'admin') return;
            if(confirm(`Apakah Anda yakin ingin MENGHAPUS secara permanen data log ${kategori} ini dari database PARENTEN?`)) {
                DB_MASTER[kategori].splice(index, 1);
                refreshApp();
                alert("Data berhasil dihapus selamanya dari sistem!");
            }
        }

        function openFormLangsungDariArsip() {
            isAdminInsertMode = true;
            openEditModalAdmin(currentArsipKategori, -1);
        }

        function openEditModalAdmin(kategori, index) {
            if(currentUserRole !== 'admin') return;
            editTargetKategori = kategori;
            editTargetIndex = index;

            let recordData = { cabang: currentArsipCabang }; 
            if(!isAdminInsertMode && index !== -1) {
                recordData = DB_MASTER[kategori][index];
                document.getElementById('modal-admin-title').innerText = "Edit Record Data (Admin Control)";
            } else {
                isAdminInsertMode = true;
                document.getElementById('modal-admin-title').innerText = `Tambah Data ${kategori.toUpperCase()} Baru`;
            }

            const fieldsGrid = document.getElementById('modal-fields-grid');
            fieldsGrid.innerHTML = '';

            const inputStyle = "w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-600 text-slate-800";
            const labelStyle = "block text-xs font-bold text-slate-500 uppercase mb-1.5 tracking-wider";

            let cabangHTML = `
                <div class="sm:col-span-2">
                    <label class="${labelStyle}">Wilayah Cabang</label>
                    <select id="e_cabang" class="${inputStyle}">
                        <option value="Lemah Abang" ${recordData.cabang === 'Lemah Abang' ? 'selected' : ''}>Cabang Lemah Abang</option>
                        <option value="Surabaya" ${recordData.cabang === 'Surabaya' ? 'selected' : ''}>Cabang Surabaya</option>
                        <option value="Medan/Semarang" ${recordData.cabang === 'Medan/Semarang' ? 'selected' : ''}>Cabang Medan/Semarang (Cab Lain)</option>
                    </select>
                </div>`;
            fieldsGrid.innerHTML += cabangHTML;

            if(kategori === 'penarikan' || kategori === 'delivery') {
                fieldsGrid.innerHTML += `
                    <div><label class="${labelStyle}">Tanggal</label><input type="date" id="e_tanggal" value="${recordData.tanggal || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Type Unit</label><input type="text" id="e_type" value="${recordData.type || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Serial Number</label><input type="text" id="e_sn" value="${recordData.sn || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Hour Meter</label><input type="number" id="e_hm" value="${recordData.hm || ''}" class="${inputStyle}" required></div>
                    <div class="sm:col-span-2"><label class="${labelStyle}">Customer</label><input type="text" id="e_customer" value="${recordData.customer || ''}" class="${inputStyle}" required></div>
                    <div class="sm:col-span-2"><label class="${labelStyle}">Kondisi / Hasil Akhir</label><input type="text" id="e_kondisi" value="${recordData.kondisi || ''}" class="${inputStyle}"></div>`;
            } else if(kategori === 'perbaikan') {
                fieldsGrid.innerHTML += `
                    <div><label class="${labelStyle}">Tanggal</label><input type="date" id="e_tanggal" value="${recordData.tanggal || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Type Unit</label><input type="text" id="e_type" value="${recordData.type || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Serial Number</label><input type="text" id="e_sn" value="${recordData.sn || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Action Kerja</label><input type="text" id="e_action" value="${recordData.action || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Nama Part</label><input type="text" id="e_partName" value="${recordData.partName || ''}" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Status Job</label>
                        <select id="e_jenisJob" class="${inputStyle}">
                            <option value="finish" ${recordData.jenisJob === 'finish' ? 'selected' : ''}>Selesai (Finish)</option>
                            <option value="proses" ${recordData.jenisJob === 'proses' ? 'selected' : ''}>Dalam Proses (In Progress)</option>
                        </select>
                    </div>`;
            } else if(kategori === 'loan') {
                fieldsGrid.innerHTML += `
                    <div><label class="${labelStyle}">Jenis Loan</label>
                        <select id="e_typeLoan" class="${inputStyle}">
                            <option value="Peminjaman" ${recordData.typeLoan === 'Peminjaman' ? 'selected' : ''}>Peminjaman</option>
                            <option value="Pengembalian" ${recordData.typeLoan === 'Pengembalian' ? 'selected' : ''}>Pengembalian</option>
                        </select>
                    </div>
                    <div><label class="${labelStyle}">Tanggal</label><input type="date" id="e_tanggal" value="${recordData.tanggal || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Part Name</label><input type="text" id="e_partName" value="${recordData.partName || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Part Number</label><input type="text" id="e_partNo" value="${recordData.partNo || ''}" class="${inputStyle}" required></div>
                    <div><label class="${labelStyle}">Quantity</label><input type="number" id="e_qty" value="${recordData.qty || '1'}" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">PIC Request</label><input type="text" id="e_pic" value="${recordData.pic || ''}" class="${inputStyle}"></div>`;
            }
            document.getElementById('modal-edit-admin').classList.remove('hidden');
        }

        function closeEditModal() {
            document.getElementById('modal-edit-admin').classList.add('hidden');
            editTargetKategori = '';
            editTargetIndex = -1;
            isAdminInsertMode = false;
        }

        function handleSaveEditAdmin(e) {
            e.preventDefault();
            if(currentUserRole !== 'admin') return;

            let dataRow = {};
            if(!isAdminInsertMode && editTargetIndex !== -1) {
                dataRow = DB_MASTER[editTargetKategori][editTargetIndex];
            }

            const fields = ['cabang', 'tanggal', 'type', 'sn', 'hm', 'customer', 'kondisi', 'action', 'partName', 'partNo', 'qty', 'jenisJob', 'typeLoan', 'pic'];
            fields.forEach(f => {
                const el = document.getElementById(`e_${f}`);
                if(el) dataRow[f] = el.value;
            });

            if(isAdminInsertMode) { DB_MASTER[editTargetKategori].push(dataRow); }
            closeEditModal();
            refreshApp();
            alert("Database PARENTEN Berhasil diperbarui dan grafik disinkronkan!");
        }

        function showQuickDataDetail(type) {
            const panel = document.getElementById('quick-detail-card');
            const title = document.getElementById('quick-detail-title');
            const badge = document.getElementById('quick-detail-badge');
            const thead = document.getElementById('quick-detail-thead');
            const tbody = document.getElementById('quick-detail-tbody');
            panel.classList.remove('hidden');
            tbody.innerHTML = '';
            let dataList = DB_MASTER[type] || [];
            
            if(type==='penarikan') {
                title.innerText = "Rincian Ringkas - Penarikan Unit";
                badge.className = "w-2.5 h-5 rounded-full bg-blue-600";
                thead.innerHTML = `<tr><th class="p-3">Tanggal</th><th class="p-3">Cabang</th><th class="p-3">Type Unit</th><th class="p-3">S/N</th><th class="p-3">Customer</th></tr>`;
                dataList.forEach(item=>{ tbody.innerHTML += `<tr class="hover:bg-slate-50"><td class="p-3">${item.tanggal}</td><td class="p-3 font-bold">${item.cabang}</td><td class="p-3">${item.type}</td><td class="p-3 font-mono">${item.sn}</td><td class="p-3">${item.customer}</td></tr>`; });
            } else if(type==='perbaikan') {
                title.innerText = "Rincian Ringkas - Perbaikan Unit";
                badge.className = "w-2.5 h-5 rounded-full bg-amber-500";
                thead.innerHTML = `<tr><th class="p-3">Tanggal</th><th class="p-3">Cabang</th><th class="p-3">Type</th><th class="p-3">Tindakan</th></tr>`;
                dataList.forEach(item=>{ tbody.innerHTML += `<tr class="hover:bg-slate-50"><td class="p-3">${item.tanggal}</td><td class="p-3 font-bold">${item.cabang}</td><td class="p-3">${item.type}</td><td class="p-3">${item.action}</td></tr>`; });
            } else {
                title.innerText = "Rincian Ringkas - RFU Delivery";
                badge.className = "w-2.5 h-5 rounded-full bg-emerald-500";
                thead.innerHTML = `<tr><th class="p-3">Tanggal</th><th class="p-3">Cabang</th><th class="p-3">Type</th><th class="p-3">Hasil</th></tr>`;
                dataList.forEach(item=>{ tbody.innerHTML += `<tr class="hover:bg-slate-50"><td class="p-3">${item.tanggal}</td><td class="p-3 font-bold">${item.cabang}</td><td class="p-3">${item.type}</td><td class="p-3 font-bold text-emerald-600">${item.kondisi}</td></tr>`; });
            }
            panel.scrollIntoView({ behavior: 'smooth' });
        }

        function openForm(type) {
            activeCurrentFormType = type;
            isAdminInsertMode = false;
            const container = document.getElementById('form-container');
            const fieldsGrid = document.getElementById('form-fields-grid');
            container.classList.remove('hidden');
            fieldsGrid.innerHTML = '';
            
            const inputStyle = "w-full p-3 bg-slate-50 border border-slate-200 rounded-xl text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-600";
            const labelStyle = "block text-xs font-bold text-slate-600 uppercase mb-1.5";

            if(type === 'penarikan' || type === 'delivery') {
                fieldsGrid.innerHTML = `
                    <div><label class="${labelStyle}">Tanggal</label><input type="date" required id="f_tanggal" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Type Unit</label><input type="text" required id="f_type" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Serial Number</label><input type="text" required id="f_sn" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Hour Meter</label><input type="number" required id="f_hm" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Customer</label><input type="text" required id="f_customer" class="${inputStyle}"></div>
                    <div class="md:col-span-2"><label class="${labelStyle}">Kondisi Aktual</label><input type="text" id="f_kondisi" class="${inputStyle}"></div>`;
            } else if(type === 'perbaikan') {
                fieldsGrid.innerHTML = `
                    <div><label class="${labelStyle}">Tanggal</label><input type="date" required id="f_tanggal" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Type Unit</label><input type="text" required id="f_type" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Serial Number</label><input type="text" required id="f_sn" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Action Kerja</label><input type="text" required id="f_action" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Nama Part</label><input type="text" id="f_partName" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Status Job</label><select id="f_jenisJob" class="${inputStyle}"><option value="finish">Finish</option><option value="proses">In Progress</option></select></div>`;
            } else if(type === 'loan') {
                fieldsGrid.innerHTML = `
                    <div><label class="${labelStyle}">Type Loan</label><select id="f_typeLoan" class="${inputStyle}"><option value="Peminjaman">Peminjaman</option><option value="Pengembalian">Pengembalian</option></select></div>
                    <div><label class="${labelStyle}">Tanggal</label><input type="date" required id="f_tanggal" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Part Name</label><input type="text" required id="f_partName" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Part Number</label><input type="text" required id="f_partNo" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">Quantity</label><input type="number" id="f_qty" value="1" class="${inputStyle}"></div>
                    <div><label class="${labelStyle}">PIC</label><input type="text" id="f_pic" class="${inputStyle}"></div>`;
            }
        }

        function closeFormContainer() { document.getElementById('form-container').classList.add('hidden'); }

        function handleSubmitForm(e) {
            e.preventDefault();
            const cabangSelected = document.getElementById('input-cabang').value;
            let dataRow = { cabang: cabangSelected };
            
            const fields = ['tanggal', 'type', 'sn', 'hm', 'customer', 'kondisi', 'action', 'partName', 'partNo', 'qty', 'jenisJob', 'typeLoan', 'pic'];
            fields.forEach(f => {
                const el = document.getElementById(`f_${f}`);
                if(el) dataRow[f] = el.value;
            });

            DB_MASTER[activeCurrentFormType].push(dataRow);
            document.getElementById('form-container').classList.add('hidden');
            refreshApp();
            e.target.reset();
            alert("Data berhasil disimpan oleh operator lapangan!");
        }

        function updateDashboardCounters() {
            document.getElementById('count-penarikan').innerText = DB_MASTER.penarikan.length;
            document.getElementById('count-perbaikan').innerText = DB_MASTER.perbaikan.length;
            document.getElementById('count-delivery').innerText = DB_MASTER.delivery.length;
        }

        function extractMonthlyDataReal(datasetArray, branchName) {
            let counts = [0, 0, 0, 0, 0]; 
            datasetArray.forEach(item => {
                if(item.cabang === branchName && item.tanggal) {
                    let bulan = new Date(item.tanggal).getMonth(); 
                    if(bulan >= 0 && bulan <= 4) { counts[bulan] += 1; }
                }
            });
            return counts;
        }

        function renderAllChartsAktual() {
            const monthsLabel = ['Jan', 'Feb', 'Mar', 'Apr', 'Mei'];
            
            // CONFIGURATION OPTION UNTUK MENGUNCI SUMBU KIRI AGAR HANYA BILANGAN BULAT SATUAN (TIDAK ADA 0,1)
            const opts = { 
                responsive: true, 
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1, // Memaksa step lompatan grafik per 1 satuan (bilangan bulat)
                            callback: function(value) {
                                if (Math.floor(value) === value) { return value; }
                            }
                        }
                    }
                }
            };
            
            let dataLA = extractMonthlyDataReal(DB_MASTER.penarikan, 'Lemah Abang');
            let dataSBY = extractMonthlyDataReal(DB_MASTER.penarikan, 'Surabaya');
            let dataMDN = extractMonthlyDataReal(DB_MASTER.penarikan, 'Medan/Semarang');
            
            let rfuLA = extractMonthlyDataReal(DB_MASTER.delivery, 'Lemah Abang');
            let rfuSBY = extractMonthlyDataReal(DB_MASTER.delivery, 'Surabaya');
            let rfuMDN = extractMonthlyDataReal(DB_MASTER.delivery, 'Medan/Semarang');

            Object.keys(instancesChart).forEach(key => { if(instancesChart[key]) instancesChart[key].destroy(); });

            // Render grafik dengan option presisi satuan bulat baru
            instancesChart.LA = new Chart(document.getElementById('chartLA'), { type: 'bar', data: { labels: monthsLabel, datasets: [{ type: 'line', label: 'Tren', data: dataLA, borderColor: '#f97316', tension: 0.2 }, { label: 'Unit', data: dataLA, backgroundColor: '#1e3a8a' }] }, options: opts });
            instancesChart.SBY = new Chart(document.getElementById('chartSBY'), { type: 'bar', data: { labels: monthsLabel, datasets: [{ type: 'line', label: 'Tren', data: dataSBY, borderColor: '#f97316', tension: 0.2 }, { label: 'Unit', data: dataSBY, backgroundColor: '#0284c7' }] }, options: opts });
            instancesChart.MDN = new Chart(document.getElementById('chartMDN'), { type: 'bar', data: { labels: monthsLabel, datasets: [{ type: 'line', label: 'Tren', data: dataMDN, borderColor: '#f97316', tension: 0.2 }, { label: 'Unit', data: dataMDN, backgroundColor: '#7c3aed' }] }, options: opts });
            instancesChart.RFU = new Chart(document.getElementById('chartRFU'), { type: 'bar', data: { labels: monthsLabel, datasets: [{ label: 'LA', data: rfuLA, backgroundColor: '#3b82f6' }, { label: 'SBY', data: rfuSBY, backgroundColor: '#10b981' }, { label: 'MDN', data: rfuMDN, backgroundColor: '#8b5cf6' }] }, options: opts });
        }

        function renderRFUTable() {
            const tbody = document.getElementById('body-rfu');
            tbody.innerHTML = '';
            DB_MASTER.delivery.forEach(item => {
                tbody.innerHTML += `<tr><td class="p-4">${item.tanggal}</td><td class="p-4">${item.cabang}</td><td class="p-4 font-medium">${item.type}</td><td class="p-4 font-mono">${item.sn}</td><td class="p-4">${item.hm || 0} Hrs</td><td class="p-4 text-emerald-600 font-bold">${item.kondisi}</td></tr>`;
            });
        }

        function handleSearch() {
            const query = document.getElementById('global-search').value.toLowerCase();
            if(!query) return;
            switchMenu('rfu');
        }

        function exportAllToExcel() {
            if(currentUserRole !== 'admin') return;
            const wb = XLSX.utils.book_new();
            Object.keys(DB_MASTER).forEach(menuKey => {
                const ws = XLSX.utils.json_to_sheet(DB_MASTER[menuKey]);
                XLSX.utils.book_append_sheet(wb, ws, menuKey.toUpperCase());
            });
            XLSX.writeFile(wb, "PARENTEN_Master_Database_Fix.xlsx");
        }
    </script>
